{
  "name": "@kule/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Backend API for Kule Army Builder",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsx build.ts",
    "start": "node dist/index.js",
    "test": "node --test --import tsx 'src/__tests__/*.test.ts' 'src/__tests__/**/*.test.ts'",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx src/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "@trpc/server": "^11.0.0",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.0.0",
    "resend": "^4.0.0",
    "ulid": "^2.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.14.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.16.0",
    "typescript": "^5.4.0"
  }
}
