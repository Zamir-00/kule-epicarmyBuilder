# Local development env vars for apps/api.
# Copy this file to apps/api/.env and fill in values for the ones you want to override.
# .env is git-ignored; .env.example is committed.

# Core (env.ts has defaults; uncomment to override)
# NODE_ENV=development
# PORT=3000
# DATABASE_PATH=./data/prod.db

# Email transport. If both are set, the server uses Resend to send real magic-link
# emails. If either is missing, magic-link content is logged to stdout (dev-friendly).
# Sign up at https://resend.com for a free API key.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Session signing (REQUIRED in production; for local dev a static value is fine).
# Generate a production secret with: openssl rand -base64 32
# SESSION_SECRET=local-dev-secret-32-bytes-minimum-aaa

# Public origin for magic-link URLs in the email body.
# Defaults to http://localhost:${PORT} in dev.
# BASE_URL=http://localhost:3000

# Static UI directory override. Auto-detected from the monorepo / flat-deploy
# layout — usually leave unset. Only set if you've moved war/ to a non-standard path.
# WAR_ROOT=/absolute/path/to/war
