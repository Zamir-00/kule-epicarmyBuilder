    {
      "id": "mirali_fortified_positions",
      "name": "Mirali Fortified Positions",
      "text": "Bunkers are Fortifications, see EA 1.8.4. Gun Emplacements provide vehicles with a cover save that works like an infantry cover save, see EA 1.8.3. Gun Emplacements can hold one unit. Bunkers can hold three units."
    },
    {
      "id": "commissar_allowance",
      "name": "Commissar Allowance",
      "text": "Mirali Skyraiders armies are allowed 1 Commissar per 500 points available."
    }
