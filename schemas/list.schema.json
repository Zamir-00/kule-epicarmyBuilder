{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://kule.example/schemas/list.schema.json",
  "title": "EpicArmyBuilder army list",
  "description": "Schema for war/lists/*.json army list files. Intentionally loose (Phase 1): all existing files must validate. Two files (EL_mymeara_NETEA.json, TEMPLATE.json) are known-invalid JSON and are excluded from validation.",
  "type": "object",
  "required": ["sections"],
  "additionalProperties": true,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": { "type": "string" },
    "list_id": { "type": "string" },
    "faction_id": { "type": "string" },
    "ruleset": { "type": "string" },
    "version": { "type": "string" },
    "by": { "type": "string" },
    "notes": {
      "oneOf": [
        {
          "type": "array",
          "items": { "type": "string" }
        },
        { "type": "string" }
      ]
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "formations"],
        "additionalProperties": true,
        "properties": {
          "id": {},
          "name": { "type": "string" },
          "formations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name"],
              "additionalProperties": true,
              "properties": {
                "id": {
                  "oneOf": [
                    { "type": "integer" },
                    { "type": "string" }
                  ]
                },
                "string_id": { "type": "string" },
                "name": { "type": "string" },
                "pts": {},
                "units": {},
                "upgrades": {
                  "type": "array",
                  "items": {}
                },
                "cost_pts": {},
                "swap_slots": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["string_id", "label", "variants"],
                    "additionalProperties": true,
                    "properties": {
                      "string_id": { "type": "string", "minLength": 1 },
                      "label": { "type": "string", "minLength": 1 },
                      "variants": {
                        "type": "array",
                        "minItems": 2,
                        "items": {
                          "type": "object",
                          "required": ["upgrade_id"],
                          "additionalProperties": true,
                          "properties": {
                            "upgrade_id": {
                              "oneOf": [
                                { "type": "integer" },
                                { "type": "string" }
                              ]
                            },
                            "is_default": { "type": "boolean" }
                          }
                        }
                      }
                    }
                  }
                },
                "loadout_slots": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["string_id", "label", "variants"],
                    "additionalProperties": true,
                    "properties": {
                      "string_id": { "type": "string", "minLength": 1 },
                      "label": { "type": "string", "minLength": 1 },
                      "min": { "type": "integer", "minimum": 0 },
                      "max": { "type": "integer", "minimum": 1 },
                      "variants": {
                        "type": "array",
                        "minItems": 1,
                        "items": {
                          "type": "object",
                          "required": ["upgrade_id"],
                          "additionalProperties": true,
                          "properties": {
                            "upgrade_id": {
                              "oneOf": [
                                { "type": "integer" },
                                { "type": "string" }
                              ]
                            },
                            "is_default": { "type": "boolean" }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "upgrades": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "oneOf": [
              { "type": "integer" },
              { "type": "string" }
            ]
          },
          "string_id": { "type": "string" },
          "name": { "type": "string" },
          "pts": {},
          "cost_pts": {},
          "upgrades": {
            "type": "array",
            "items": {}
          }
        }
      }
    },
    "formationConstraints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "upgradeConstraints": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "fixedFormations": {
      "type": "array",
      "items": {}
    }
  }
}
